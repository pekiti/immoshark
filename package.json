{
  "name": "immoshark",
  "version": "0.2.0",
  "private": true,
  "workspaces": ["shared", "server", "client"],
  "scripts": {
    "dev": "bun run --cwd server dev & bun run --cwd client dev & wait",
    "dev:server": "bun run --cwd server dev",
    "dev:client": "bun run --cwd client dev",
    "build": "bun run --cwd client build",
    "seed": "bun run --cwd server seed",
    "test": "bun test",
    "test:unit": "bun test shared/ client/ server/src/__tests__/unit/",
    "test:integration": "bun test server/src/__tests__/integration/",
    "test:smoke": "bun test server/src/__tests__/smoke/"
  }
}
